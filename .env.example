# ── UMak CSOA Photobooth Management System ────────────────────────────────
# Copy this file to .env and fill in the values

# ── Database: Supabase PostgreSQL ───────────────────────────────────────
# Transaction mode (pooler port 6543) — used for app connections
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=20"
# Session mode (pooler port 5432) — used for migrations and direct queries
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ── Authentication ───────────────────────────────────────────────────────
NEXTAUTH_SECRET="change-this-to-a-secure-random-string"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# ── Encryption (for plainPassword field) ────────────────────────────────
ENCRYPTION_KEY="change-this-to-a-secure-32-char-key"

# ── Supabase Storage (for file uploads) ────────────────────────────────
# Required for production — uploads go to Supabase Storage
# Leave empty for local dev — falls back to local filesystem (public/uploads/)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
