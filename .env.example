# ── UMak CSOA Photobooth Management System ────────────────────────────────
# Copy this file to .env and fill in the values

# ── Database (SQLite for local development) ──────────────────────────────
DATABASE_URL="file:./dev.db"

# ── Authentication ───────────────────────────────────────────────────────
NEXTAUTH_SECRET="change-this-to-a-secure-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ── Supabase PostgreSQL (for production deployment) ──────────────────────
# 1. Uncomment these lines
# 2. Comment out the SQLite DATABASE_URL above
# 3. Update the schema.prisma provider from "sqlite" to "postgresql"
#    (use prisma/schema.production.prisma as reference)
# 4. Make sure your Supabase project is active (not paused)
# DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=20"
# DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"
